%%{ init: { 'theme': 'base', 'themeVariables': { 'primaryColor': '#1a1a2e', 'primaryTextColor': '#e0e0e0', 'primaryBorderColor': '#4a4a6a', 'lineColor': '#7c7caa', 'secondaryColor': '#16213e', 'tertiaryColor': '#0f3460', 'fontFamily': 'SF Mono, Menlo, monospace' } } }%%

flowchart TB
    %% ═══════════════════════════════════════════════════
    %% USER / HARDWARE LAYER
    %% ═══════════════════════════════════════════════════

    subgraph USER["User & Hardware"]
        direction LR
        MIC["Microphone"]
        SPEAKER["Speaker"]
        DISPLAY["Display"]
        KB_MOUSE["Keyboard & Mouse"]
    end

    %% ═══════════════════════════════════════════════════
    %% MENU BAR UI (main thread)
    %% ═══════════════════════════════════════════════════

    subgraph MENUBAR["aura-menubar  (main thread, Cocoa FFI)"]
        direction TB
        STATUS["NSStatusItem<br/>Colored Dot"]
        POPOVER["NSPopover<br/>Chat Transcript"]
        CTXMENU["Context Menu<br/>Reconnect | Quit"]
        TIMER["NSTimer 50ms<br/>Poll Messages"]
    end

    %% ═══════════════════════════════════════════════════
    %% DAEMON ORCHESTRATOR (tokio runtime)
    %% ═══════════════════════════════════════════════════

    subgraph DAEMON["aura-daemon  (orchestrator, tokio runtime)"]
        direction TB
        MAIN["main()<br/>CLI + Setup + API Key"]
        PROCESSOR["run_processor()<br/>Event Loop"]
        EVENTBUS["EventBus<br/>broadcast channel"]

        subgraph MIC_BRIDGE["Mic Bridge"]
            direction LR
            STD_CHAN["std::sync::mpsc"]
            TOKIO_CHAN["tokio::mpsc<br/>(cap: 256)"]
            ENERGY["RMS Energy Gate<br/>threshold: 0.04"]
        end
    end

    %% ═══════════════════════════════════════════════════
    %% AUDIO CRATES
    %% ═══════════════════════════════════════════════════

    subgraph VOICE["aura-voice"]
        direction TB
        CAPTURE["AudioCapture<br/>cpal, 48kHz -> 16kHz<br/>SincFixedIn resampler"]
        PLAYBACK["AudioPlayer<br/>rodio Sink, 24kHz<br/>dedicated thread"]
        PREBUF["PreBuffer<br/>80ms jitter absorb"]
    end

    %% ═══════════════════════════════════════════════════
    %% GEMINI SESSION
    %% ═══════════════════════════════════════════════════

    subgraph GEMINI["aura-gemini  (WebSocket client)"]
        direction TB
        SESSION["GeminiLiveSession<br/>connection_loop()"]
        SETUP["Setup Message<br/>model + tools + prompt<br/>+ session resumption"]
        EVENTS["GeminiEvent broadcast<br/>Connected | AudioResponse<br/>ToolCall | Interrupted<br/>TurnComplete | Error"]

        subgraph CHANNELS["mpsc Channels"]
            direction LR
            AUDIO_TX["audio_tx<br/>f32 PCM 16kHz"]
            VIDEO_TX["video_tx<br/>JPEG base64"]
            TEXT_TX["text_tx<br/>context msgs"]
            TOOL_TX["tool_response_tx<br/>JSON results"]
        end
    end

    %% ═══════════════════════════════════════════════════
    %% GOOGLE CLOUD
    %% ═══════════════════════════════════════════════════

    subgraph CLOUD["Google Cloud"]
        direction TB
        PROXY["aura-proxy<br/>Cloud Run (axum)<br/>WebSocket relay"]
        GEMINI_API["Gemini Live API<br/>gemini-2.5-flash<br/>native-audio-preview<br/>v1beta BidiGenerateContent"]
    end

    %% ═══════════════════════════════════════════════════
    %% SCREEN / VISION
    %% ═══════════════════════════════════════════════════

    subgraph SCREEN["aura-screen  (vision loop)"]
        direction TB
        CGD["CGDisplay capture<br/>BGRA -> RGB -> JPEG<br/>max 1920px wide"]
        HASH["FNV-1a hash<br/>2048-pixel sample<br/>change detection"]
        CTX["MacOSScreenReader<br/>osascript queries"]
        TRIGGER["CaptureTrigger<br/>AtomicBool flag"]
    end

    %% ═══════════════════════════════════════════════════
    %% TOOL EXECUTION
    %% ═══════════════════════════════════════════════════

    subgraph TOOLS["Tool Execution  (9 tools, semaphore: 8)"]
        direction TB

        subgraph BRIDGE["aura-bridge"]
            SCRIPT["ScriptExecutor<br/>sandbox-exec + osascript<br/>AppleScript / JXA"]
            SAFETY["Safety Checks<br/>blocked patterns:<br/>rm -rf, sudo, dd, chmod 777<br/>$.system, ObjC.import"]
        end

        subgraph INPUT["aura-input  (CGEvent)"]
            MOUSE["mouse: move, click,<br/>scroll, drag"]
            KEYBOARD["keyboard: type_text,<br/>press_key + modifiers"]
        end

        SCREEN_TOOL["get_screen_context"]
        SHUTDOWN_TOOL["shutdown_aura<br/>(inline, breaks loop)"]
    end

    %% ═══════════════════════════════════════════════════
    %% STORAGE
    %% ═══════════════════════════════════════════════════

    subgraph MEMORY["aura-memory  (SQLite, WAL mode)"]
        direction TB
        DB[("aura.db<br/>~/.local/share/aura/")]
        SESSIONS["sessions table<br/>id, started_at, summary"]
        MESSAGES["messages table<br/>role, content, timestamp"]
        SETTINGS["settings table<br/>resumption_handle"]
    end

    %% ═══════════════════════════════════════════════════
    %% DATA FLOW CONNECTIONS
    %% ═══════════════════════════════════════════════════

    %% Audio In: Mic -> Capture -> Bridge -> Gemini
    MIC -->|"raw audio"| CAPTURE
    CAPTURE -->|"16kHz f32 PCM"| STD_CHAN
    STD_CHAN --> TOKIO_CHAN
    TOKIO_CHAN --> ENERGY
    ENERGY -->|"gated audio"| AUDIO_TX
    AUDIO_TX -->|"base64 PCM"| SESSION

    %% Audio Out: Gemini -> Playback -> Speaker
    SESSION -->|"AudioResponse"| EVENTS
    EVENTS -->|"24kHz f32 PCM"| PREBUF
    PREBUF --> PLAYBACK
    PLAYBACK -->|"24kHz audio"| SPEAKER

    %% Vision Loop: Display -> Screen -> Gemini
    DISPLAY -->|"screen content"| CGD
    CGD --> HASH
    HASH -->|"changed frames only"| VIDEO_TX
    VIDEO_TX -->|"JPEG base64 @ 1fps"| SESSION

    %% Tool Flow: Gemini -> ToolCall -> Execute -> Result -> Gemini
    EVENTS -->|"ToolCall event"| PROCESSOR
    PROCESSOR -->|"dispatch"| TOOLS
    SCRIPT -->|"osascript"| KB_MOUSE
    MOUSE -->|"CGEvent"| KB_MOUSE
    KEYBOARD -->|"CGEvent"| KB_MOUSE
    SCREEN_TOOL --> CTX
    CTX -->|"osascript + pbpaste"| KB_MOUSE
    TOOLS -->|"JSON result"| TOOL_TX
    TOOL_TX --> SESSION

    %% Post-tool capture trigger
    TOOLS -->|"trigger"| TRIGGER
    TRIGGER -->|"immediate capture"| CGD

    %% WebSocket: Session <-> Cloud
    SESSION <-->|"WebSocket<br/>tokio-tungstenite"| GEMINI_API
    SESSION <-.->|"optional relay"| PROXY
    PROXY <-->|"bidirectional WS"| GEMINI_API

    %% Menu Bar: Status updates from processor
    PROCESSOR -->|"MenuBarMessage<br/>tokio::mpsc"| TIMER
    TIMER --> STATUS
    TIMER --> POPOVER

    %% Menu Bar -> Daemon signals
    CTXMENU -->|"reconnect_tx"| MAIN
    CTXMENU -->|"shutdown_tx"| MAIN

    %% Memory persistence
    PROCESSOR -->|"add_message"| DB
    PROCESSOR -->|"set_setting<br/>(resumption handle)"| SETTINGS

    %% Barge-in path
    EVENTS -->|"Interrupted"| PROCESSOR
    PROCESSOR -->|"stop()"| PLAYBACK

    %% Menu bar status colors
    STATUS -.-|"Green pulsing = listening<br/>Amber = tool running<br/>Red = error<br/>Gray = disconnected"| USER

    %% ═══════════════════════════════════════════════════
    %% STYLING
    %% ═══════════════════════════════════════════════════

    classDef default fill:#1e1e2e,stroke:#4a4a6a,color:#cdd6f4,stroke-width:1px
    classDef crate fill:#1e1e3e,stroke:#7c7cff,color:#cdd6f4,stroke-width:2px
    classDef cloud fill:#0d2137,stroke:#4cc9f0,color:#cdd6f4,stroke-width:2px
    classDef storage fill:#1e2d1e,stroke:#4caf50,color:#cdd6f4,stroke-width:2px
    classDef user fill:#2d1e2d,stroke:#e040fb,color:#cdd6f4,stroke-width:2px
    classDef danger fill:#2d1e1e,stroke:#ef5350,color:#cdd6f4,stroke-width:1px

    class MIC,SPEAKER,DISPLAY,KB_MOUSE user
    class CAPTURE,PLAYBACK,PREBUF crate
    class SESSION,SETUP,EVENTS,AUDIO_TX,VIDEO_TX,TEXT_TX,TOOL_TX crate
    class CGD,HASH,CTX,TRIGGER crate
    class SCRIPT,SAFETY,MOUSE,KEYBOARD crate
    class SCREEN_TOOL,SHUTDOWN_TOOL crate
    class STATUS,POPOVER,CTXMENU,TIMER crate
    class MAIN,PROCESSOR,EVENTBUS,STD_CHAN,TOKIO_CHAN,ENERGY crate
    class PROXY,GEMINI_API cloud
    class DB,SESSIONS,MESSAGES,SETTINGS storage
    class SAFETY danger
