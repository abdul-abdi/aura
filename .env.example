# Required — Gemini API key (get from https://aistudio.google.com)
GEMINI_API_KEY=

# Optional — Proxy relay (for Cloud Run WebSocket proxy)
AURA_PROXY_URL=
AURA_PROXY_AUTH_TOKEN=

# Optional — Cloud memory sync
AURA_FIRESTORE_PROJECT_ID=
AURA_FIREBASE_API_KEY=
AURA_DEVICE_ID=
AURA_CLOUD_RUN_URL=
AURA_CLOUD_RUN_AUTH_TOKEN=

# Optional — GCP deployment
AURA_CLOUD_PROJECT=
AURA_CLOUD_REGION=us-central1
